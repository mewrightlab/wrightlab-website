---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Wright Lab — University of Iowa">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-inner">
      <div>
        <span class="section-eyebrow">Wright Laboratory</span>
        <h1>Mapping the molecular circuitry of human disease.</h1>
        <p class="tagline">
          Proximal interaction networks to annotate, predict, and interrogate protein function &mdash;
          built on quantitative mass spectrometry.
        </p>
        <div class="hero-actions">
          <a href="/research/" class="button">Explore our research</a>
          <a href="/join/" class="button secondary">Join the lab</a>
        </div>
      </div>
      <div class="hero-image">
        <img src="/images/hero-atlas.png" alt="Cellular atlas — a map-like view of a cell showing organelle districts and protein interaction neighborhoods" />
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="section surface">
    <div class="section-inner" style="max-width: 820px; text-align: center;">
      <span class="section-eyebrow">Our Mission</span>
      <h2>From subcellular protein complexes to druggable targets.</h2>
      <p style="font-size: 1.1rem; color: var(--color-text-muted);">
        The Wright laboratory leverages quantitative mass spectrometry platforms to probe the
        subcellular composition of protein complexes in preclinical models of human disease.
        Our goal is to understand the molecular circuitry of cellular signaling to identify
        the most druggable protein receptors &mdash; either to selectively activate latent cell
        death pathways, or to facilitate growth arrest through cellular differentiation.
      </p>
      <p style="font-size: 1.1rem; color: var(--color-text-muted);">
        Our approach annotates subcellular protein&ndash;protein interactions using proximity-labeling
        methods coupled with quantitative mass spectrometry.
      </p>
    </div>
  </section>

  <!-- Research focus areas -->
  <section class="section">
    <div class="section-inner">
      <div style="text-align: center; margin-bottom: 4rem;">
        <span class="section-eyebrow">Research Focus</span>
        <h2>Three pillars of the Wright Lab.</h2>
      </div>

      <div class="feature-row">
        <div class="feature-row-text">
          <span class="feature-number">1</span>
          <h2>Proximity interaction networks</h2>
          <p>
            Constructing proximity interaction networks for key regulators of cellular
            proliferation, cell death, and cellular differentiation &mdash; revealing how
            protein complexes coordinate cell-fate decisions.
          </p>
          <a href="/research/" class="button secondary">Read more</a>
        </div>
        <div class="feature-row-image">
          <div class="image-placeholder">
            Focus Area 1 figure
            <small>(network or pathway diagram)</small>
          </div>
        </div>
      </div>

      <div class="feature-row reverse">
        <div class="feature-row-text">
          <span class="feature-number">2</span>
          <h2>Novel proximity enzymes</h2>
          <p>
            Developing novel proximity-labeling enzymes to capture post-translational
            modifications in complex biological matrices &mdash; extending the reach of
            quantitative proteomics into hard-to-study regimes.
          </p>
          <a href="/research/" class="button secondary">Read more</a>
        </div>
        <div class="feature-row-image">
          <div class="image-placeholder">
            Focus Area 2 figure
            <small>(enzyme structure or labeling schematic)</small>
          </div>
        </div>
      </div>

      <div class="feature-row">
        <div class="feature-row-text">
          <span class="feature-number">3</span>
          <h2>Reagents &amp; methods for cell biology</h2>
          <p>
            Optimizing cell biology reagents and methods to interrogate the molecular
            function of protein complexes &mdash; enabling reproducible, mechanism-level
            insight in preclinical disease models.
          </p>
          <a href="/research/" class="button secondary">Read more</a>
        </div>
        <div class="feature-row-image">
          <div class="image-placeholder">
            Focus Area 3 figure
            <small>(method illustration or reagent imagery)</small>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="section dark">
    <div class="section-inner cta">
      <span class="section-eyebrow" style="color: var(--color-accent);">Join Us</span>
      <h2>Interested in collaborating or joining the lab?</h2>
      <p>
        We welcome inquiries from prospective graduate students, postdoctoral researchers,
        and collaborators working at the intersection of proteomics and disease biology.
      </p>
      <div class="hero-actions" style="justify-content: center;">
        <a href="/join/" class="button">Open positions</a>
        <a href="/contact/" class="button secondary" style="border-color: var(--color-accent); color: var(--color-accent);">Contact us</a>
      </div>
    </div>
  </section>

  <style>
    .hero-image img {
      width: 100%;
      height: auto;
      border-radius: 12px;
      box-shadow: 0 16px 40px rgba(15, 44, 46, 0.12);
      display: block;
    }
  </style>
</Layout>
