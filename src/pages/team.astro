---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Team — Wright Lab">
  <main class="page wide">
    <span class="section-eyebrow">Team</span>
    <h1>The people of the Wright Lab</h1>
    <p class="lead">The students, postdocs, and staff scientists who power our research.</p>

    <h2>Current Members</h2>
    <div class="card-grid" style="margin-top: 1.5rem;">
      <div class="card">
        <div class="image-placeholder square" style="margin-bottom: 1rem;">Headshot</div>
        <h3>Member Name</h3>
        <p class="muted">Role &middot; Joined YYYY</p>
        <p>Short bio &mdash; research interests, background, current project.</p>
      </div>
      <div class="card">
        <div class="image-placeholder square" style="margin-bottom: 1rem;">Headshot</div>
        <h3>Member Name</h3>
        <p class="muted">Role &middot; Joined YYYY</p>
        <p>Short bio &mdash; research interests, background, current project.</p>
      </div>
      <div class="card">
        <div class="image-placeholder square" style="margin-bottom: 1rem;">Headshot</div>
        <h3>Member Name</h3>
        <p class="muted">Role &middot; Joined YYYY</p>
        <p>Short bio &mdash; research interests, background, current project.</p>
      </div>
    </div>

    <h2 style="margin-top: 4rem;">Alumni</h2>
    <p class="muted"><em>Alumni profiles coming soon.</em></p>
  </main>
</Layout>
